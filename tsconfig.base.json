{
  "compilerOptions": {
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "node"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "outDir": "./dist",
    "paths": {
      "@mobile-data": ["./apps/mobile/src/data"],
      "@mobile-data/*": ["./apps/mobile/src/data/*"],
      "@solid-client": ["./packages/solid-client/src"],
      "@solid-client/*": ["./packages/solid-client/src/*"],
      "@shared/*": ["./packages/shared/src/*"],
      "@platform/assets/runtimeAudio": [
        "./packages/shared/src/platform/assets/runtimeAudio"
      ],
      "@platform/*": ["./packages/shared/src/platform/*"],
      "@test-support/*": ["./tooling/test-support/*"]
    }
  }
}
