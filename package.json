{
  "name": "haven",
  "version": "1.8.1",
  "description": "Haven",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/redrix-dev/haven.git"
  },
  "scripts": {
    "lint": "eslint \"{apps,packages,tooling}/**/*.{js,ts,tsx}\"",
    "check:shared-portable": "node tooling/scripts/check-shared-portable.mjs",
    "check:shared-hex": "node tooling/scripts/check-shared-hex-literals.mjs",
    "themes:generate": "npx tsx tooling/scripts/generate-theme-bridge.ts",
    "check:themes": "node tooling/scripts/check-theme-bridge.mjs",
    "check:chat-surface": "node tooling/scripts/check-chat-surface.mjs",
    "check:mobile-uniwind": "node tooling/scripts/mobile/check-uniwind-theme-usage.mjs",
    "check:mobile-typography": "node tooling/scripts/mobile/check-mobile-typography.mjs",
    "test:unit": "vitest run packages/shared/src/core/__tests__ packages/shared/src/infrastructure/platform/__tests__ packages/shared/src/themes/__tests__ packages/shared/src/features/auth/domain/__tests__ packages/shared/src/features/messaging/lib/__tests__ packages/shared/src/features/messaging/utils/__tests__ packages/shared/src/features/notifications/utils/__tests__ packages/solid-client/src/data/direct-messages/__tests__ packages/solid-client/src/data/social/__tests__ packages/solid-client/src/features/voice/__tests__ apps/mobile/src/data/__tests__ apps/mobile/src/features/notifications/utils/__tests__",
    "test:cleave": "npm run lint && npm run check:shared-portable && npm run typecheck && npm run mobile:typecheck && npm run mobile:bundle && npm run test:unit",
    "test:backend": "node tooling/scripts/test/run-vitest-with-local-env.mjs backend",
    "test:db:users": "node tooling/scripts/test/bootstrap-local-auth-users.mjs",
    "test:db:fixtures": "node tooling/scripts/test/run-supabase-sql-suite.mjs --fixtures-only",
    "test:db:rls": "node tooling/scripts/test/run-supabase-sql-suite.mjs",
    "test:db:quick": "node tooling/scripts/test/run-supabase-sql-suite.mjs --skip-fixtures",
    "test:db": "node tooling/scripts/test/run-db-suite.mjs",
    "supabase:types": "node tooling/scripts/generate-supabase-types.mjs",
    "test:notifications:smoke": "node tooling/scripts/test/run-notification-dispatch-smoke.mjs",
    "test:signoff": "node tooling/scripts/test/generate-test-signoff.mjs",
    "test:signoff:release": "node tooling/scripts/test/generate-test-signoff.mjs --mode release",
    "test:report": "node tooling/scripts/test/generate-test-report.mjs",
    "checkin": "node tooling/scripts/checkin.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.shared.json && tsc --noEmit --project tsconfig.node.json",
    "typecheck:solid": "tsc --noEmit --project apps/tauri/tsconfig.json",
    "test:all": "npm run lint && npm run check:shared-portable && npm run check:themes && npm run typecheck && npm run test:unit && npm run test:db && npm run test:backend",
    "test:ci": "npm run test:cleave && npm run test:db && npm run test:backend",
    "ci:verify": "npm run test:ci",
    "dev:solid": "vite --config apps/tauri/vite.config.ts",
    "build:solid": "vite build --config apps/tauri/vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "cd apps/tauri && tauri dev",
    "tauri:build": "cd apps/tauri && tauri build",
    "mobile:preflight": "node tooling/scripts/mobile/preflight.mjs",
    "mobile:ownership": "node tooling/scripts/mobile/check-dependency-ownership.mjs",
    "mobile:doctor": "node tooling/scripts/mobile/doctor.mjs",
    "mobile:dev:metro": "node tooling/scripts/mobile/run-in-mobile.mjs npm run dev:metro",
    "mobile:dev:metro:clear": "node tooling/scripts/mobile/run-in-mobile.mjs npm run dev:metro:clear",
    "mobile:fastlane:build": "npm run mobile:release:check && node tooling/scripts/mobile/run-in-mobile.mjs bundle exec fastlane ios build",
    "mobile:run:ios:simulator": "node tooling/scripts/mobile/run-in-mobile.mjs npm run run:ios:simulator",
    "mobile:run:ios:device": "node tooling/scripts/mobile/run-in-mobile.mjs npm run run:ios:device",
    "mobile:run:android": "node tooling/scripts/mobile/run-in-mobile.mjs npm run run:android",
    "mobile:native:prebuild": "node tooling/scripts/mobile/run-in-mobile.mjs npm run native:prebuild",
    "mobile:eas:build": "node tooling/scripts/mobile/run-in-mobile.mjs npm run eas:build --",
    "mobile:eas:submit": "node tooling/scripts/mobile/run-in-mobile.mjs npm run eas:submit --",
    "mobile:eas:credentials": "node tooling/scripts/mobile/run-in-mobile.mjs npm run eas:credentials",
    "mobile:ota:deploy": "bash tooling/scripts/mobile/deploy-ota.sh",
    "mobile:typecheck": "node tooling/scripts/mobile/run-in-mobile.mjs npm run typecheck",
    "mobile:bundle": "node tooling/scripts/mobile/run-in-mobile.mjs npm run bundle:check",
    "mobile:release:check": "npm run check:themes && npm run check:chat-surface && npm run check:mobile-uniwind && npm run check:mobile-typography && npm run mobile:preflight && npm run mobile:typecheck",
    "setup:mobile": "node tooling/scripts/mobile/run-in-mobile.mjs npm ci",
    "reset:mobile": "node tooling/scripts/mobile/reset.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": {
    "name": "redrix-dev",
    "email": "redrixdevelopment@icloud.com"
  },
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "supabase": "^2.105.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.5",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.16.1",
    "@supabase/supabase-js": "^2.107.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "clsx": "^2.1.1",
    "livekit-client": "^2.19.2",
    "lucide-solid": "^1.17.0",
    "marked": "^18.0.5",
    "solid-js": "^1.9.13",
    "tailwind-merge": "^3.4.1",
    "virtua": "^0.49.1",
    "zustand": "^5.0.12"
  }
}
