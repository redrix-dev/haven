{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": [
    "apps/mobile/src/data/**/*",
    "packages/shared/src/**/*",
    "tooling/test-support/setup/jsdom.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "packages/shared/src/lib/backend/__tests__/**/*",
    "tooling/**/*"
  ]
}
