{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "paths": {
      "@electron/*": ["./apps/electron/src/*"],
      "@web/*": ["./apps/web/src/*"],
      "@web-client/*": ["./packages/web-client/src/*"],
      "@shared/app/ui/*": ["./packages/web-client/src/app-ui/*"],
      "@shared/*": ["./packages/shared/src/*"],
      "@client/app/*": ["./packages/shared/src/app/*"],
      "@platform/assets/runtimeAudio": ["./packages/shared/src/platform/assets/runtimeAudio"],
      "@platform/*": ["./packages/shared/src/platform/*"],
      "@test-support/*": ["./tooling/test-support/*"]
    }
  },
  "include": [
    "forge.config.js",
    "webpack*.js",
    "vitest.config.ts",
    "apps/electron/src/main/**/*",
    "apps/electron/src/preload/**/*",
    "tooling/**/*",
    "packages/shared/src/platform/ipc/**/*",
    "packages/shared/src/lib/backend/__tests__/**/*"
  ],
  "exclude": ["node_modules", "dist", "tooling/test-support/setup/jsdom.ts"]
}
