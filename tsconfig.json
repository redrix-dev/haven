{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "jsx": "react",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@electron/*": ["./apps/electron/src/*"],
      "@web/*": ["./apps/web/src/*"],
      "@mobile/*": ["./apps/mobile/src/*"],
      "@shared/*": ["./packages/shared/src/*"],
      "@client/*": ["./packages/shared/src/client/*"],
      "@platform/*": ["./packages/shared/src/platform/*"],
      "@test-support/*": ["./tooling/test-support/*"]
    }
  },
  "include": [
    "apps/electron/**/*",
    "apps/web/**/*",
    "apps/mobile/**/*",
    "packages/**/*",
    "tooling/**/*"
  ],
  "exclude": [
    "node_modules",
    "apps/web/vite.config.ts",
    "apps/mobile/vite.config.ts",
    "apps/mobile/capacitor.config.ts"
  ]
}
