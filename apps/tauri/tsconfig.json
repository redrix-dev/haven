{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["vite/client"],
    "paths": {
      "@solid-client/*": ["../../packages/solid-client/src/*"],
      "@solid-bindings": ["../../packages/solid-bindings/src"],
      "@solid-bindings/*": ["../../packages/solid-bindings/src/*"]
    }
  },
  "include": [
    "src",
    "../../packages/solid-client/src",
    "../../packages/solid-bindings/src",
    "vite.config.ts"
  ]
}
