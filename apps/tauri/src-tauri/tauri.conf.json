{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Haven (Tauri spike)",
  "version": "0.1.0",
  "identifier": "com.redrixx.haven.spike",
  "build": {
    "beforeDevCommand": "npm run dev:solid",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build:solid",
    "frontendDist": "../../../dist/tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Haven — Tauri/Solid spike",
        "width": 1100,
        "height": 740,
        "minWidth": 800,
        "minHeight": 560,
        "backgroundColor": "#0d1626"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
