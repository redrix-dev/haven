{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Haven",
  "version": "2.0.1",
  "identifier": "com.redrixx.haven",
  "build": {
    "beforeDevCommand": "npm run dev:solid",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build:solid",
    "frontendDist": "../../../dist/tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Haven",
        "width": 1100,
        "height": 740,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": false,
        "backgroundColor": "#0d1626"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2Q0EyQkM5NDAzNEIzRjgKUldUNHN6UkF5U3ZLRm9kK04wS05mWnR1UE81cy9mYWNId3Btb3RKNGg4TEVHc1VZZkRKZzhSQnoK",
      "endpoints": [
        "https://github.com/redrix-dev/haven/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["haven"]
      }
    }
  }
}
