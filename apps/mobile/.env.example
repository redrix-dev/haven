# Copied to `.env` for local development (gitignored).
# Expo inlines EXPO_PUBLIC_* at bundle time.
#
# @shared/lib/supabase currently expects SUPABASE_URL / SUPABASE_ANON_KEY
# (web). For RN you will map these into a mobile Supabase factory — until
# then, defining EXPO_PUBLIC_* prepares app.config `extra` for Constants.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
