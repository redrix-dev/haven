# Copied to `.env` for local development (gitignored).
# Expo inlines EXPO_PUBLIC_* at bundle time.
#
# Mobile reads these via app.config `extra` / Constants and passes them to
# `createHavenSupabaseClient` + `initializeHavenDataFromClient` at startup.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
