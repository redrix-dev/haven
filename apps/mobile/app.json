{
  "expo": {
    "name": "Haven Mobile",
    "slug": "haven-mobile",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "haven",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-dev-client"],
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "bundleIdentifier": "com.redrix.haven.mobile"
    },
    "android": {
      "package": "com.redrix.haven.mobile"
    }
  }
}
