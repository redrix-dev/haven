{
  "expo": {
    "name": "Haven Mobile",
    "slug": "haven-mobile",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "haven",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-dev-client",
      "expo-notifications"
    ],
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "bundleIdentifier": "com.redrix.haven.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.redrix.haven.mobile"
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "eas": {
        "projectId": "ceae6631-4ddf-4d13-8bf2-952563823420"
      }
    }
  }
}
