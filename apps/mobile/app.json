{
  "expo": {
    "name": "Haven Mobile",
    "slug": "haven-mobile",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "haven",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/haven-app-icon.png",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-video",
      "expo-asset",
      "expo-font",
      "expo-sharing",
      "expo-dev-client",
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication",
            "enableScreenShareService": false
          },
          "ios": {
            "enableMultitaskingCameraAccess": false
          }
        }
      ],
      "@config-plugins/react-native-webrtc",
      "./plugins/withAndroidVoiceForegroundService",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Haven to access your camera for profile images, media sharing, and call features."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Haven to use Face ID to unlock your account securely."
        }
      ],
      "react-native-enriched-markdown",
      "expo-build-properties",
      "./plugins/withNewArchPodfileProperties",
      "./plugins/withHavenIOSNative"
    ],
    "ios": {
      "icon": "./assets/haven-app-icon.png",
      "bundleIdentifier": "com.redrix.haven.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow Haven to access your camera for media sharing and call features.",
        "NSMicrophoneUsageDescription": "Allow Haven to access your microphone for voice sessions and calls.",
        "NSPhotoLibraryUsageDescription": "Allow Haven to access your photo library to upload media attachments.",
        "NSPhotoLibraryAddUsageDescription": "Allow Haven to save shared media to your photo library.",
        "NSFaceIDUsageDescription": "Allow Haven to use Face ID for secure app access.",
        "NSLocalNetworkUsageDescription": "Haven uses your local network so this development build can find and connect to the Metro bundler on your computer.",
        "NSBonjourServices": ["_expo._tcp", "_http._tcp"],
        "UIBackgroundModes": ["audio", "voip", "remote-notification"]
      }
    },
    "android": {
      "package": "com.redrix.haven.mobile",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "USE_BIOMETRIC"
      ]
    },
    "updates": {
      "enabled": true,
      "url": "https://uapurngoeceliiwxygdn.supabase.co/functions/v1/update-manifest",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "eas": {
        "projectId": "ceae6631-4ddf-4d13-8bf2-952563823420"
      }
    }
  }
}
