{
  "name": "haven-mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "preflight": "node ../../tooling/scripts/mobile/preflight.mjs --strict",
    "dev:metro": "npm run preflight && expo start --dev-client",
    "dev:metro:clear": "npm run preflight && expo start --dev-client --clear",
    "run:ios:simulator": "npm run preflight && expo run:ios",
    "run:ios:device": "npm run preflight && expo run:ios --device",
    "run:android": "npm run preflight && expo run:android",
    "native:prebuild": "npm run preflight && expo prebuild",
    "eas:build": "npm run preflight && eas build",
    "eas:build:dev": "npm run eas:build -- --profile development",
    "eas:build:dev:ios": "npm run eas:build -- --profile development --platform ios",
    "eas:build:dev:android": "npm run eas:build -- --profile development --platform android",
    "eas:build:preview": "npm run eas:build -- --profile preview",
    "eas:build:preview:ios": "npm run eas:build -- --profile preview --platform ios",
    "eas:build:preview:android": "npm run eas:build -- --profile preview --platform android",
    "eas:build:prod": "npm run eas:build -- --profile production",
    "eas:build:prod:ios": "npm run eas:build -- --profile production --platform ios",
    "eas:build:prod:android": "npm run eas:build -- --profile production --platform android",
    "eas:submit": "npm run preflight && eas submit",
    "eas:credentials": "npm run preflight && eas credentials",
    "typecheck": "tsc --noEmit",
    "doctor": "node ../../tooling/scripts/mobile/doctor.mjs",
    "start": "npm run dev:metro",
    "start:clear": "npm run dev:metro:clear",
    "ios": "npm run run:ios:simulator",
    "ios:device": "npm run run:ios:device",
    "android": "npm run run:android",
    "prebuild": "npm run native:prebuild"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native/virtualized-lists": "^0.79.6",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "^53.0.0",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.7",
    "expo-blur": "~14.1.5",
    "expo-brightness": "~13.1.4",
    "expo-camera": "~16.1.11",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-keep-awake": "~14.1.4",
    "expo-linking": "~7.1.7",
    "expo-local-authentication": "~16.0.5",
    "expo-notifications": "~0.31.5",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-callkeep": "^4.3.16",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-voip-push-notification": "^3.3.3",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "^0.3.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.0.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "eas-cli": "^18.7.0",
    "typescript": "~5.8.3"
  }
}
