{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "types": [
      "react",
      "nativewind/types",
      "node"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@shared/app/ui/*": ["../../packages/web-client/src/app-ui/*"],
      "@client/app/*": ["../../packages/shared/src/app/*"],
      "@platform/*": ["../../packages/shared/src/platform/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./nativewind-env.d.ts",
    "nativewind-env.d.ts"
  ]
}