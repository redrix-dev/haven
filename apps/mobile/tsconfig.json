{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "types": [
      "react",
      "nativewind/types"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./nativewind-env.d.ts",
    "nativewind-env.d.ts"
  ]
}