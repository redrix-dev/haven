{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "types": [
      "react",
      "node"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@shared/*": [
        "../../packages/shared/src/*"
      ],
      "@shared/app/ui/*": [
        "../../packages/web-client/src/app-ui/*"
      ],
      "@client/app/*": [
        "../../packages/shared/src/app/*"
      ],
      "@platform/*": [
        "../../packages/shared/src/platform/*"
      ]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./uniwind-types.d.ts",
    "../../packages/shared/src/types/**/*.d.ts",
    "../../packages/shared/src/nexus/**/*.d.ts"
  ],
  "exclude": [
    "./src/screens/deprecated/**"
  ]
}